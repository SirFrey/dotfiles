  "instructions": [
    "/home/moises/projects/resorsi/resorsi-hub/plugins/hub/rules/zoho-crm.md",
    "/home/moises/projects/resorsi/resorsi-hub/plugins/hub/rules/client-comms.md",
    "/home/moises/projects/resorsi/resorsi-hub/plugins/hub/rules/gitlab.md"
  ],
  "agent": {
    "code-reviewer": {
      "description": "Reviews code for best practices and potential issues",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-20250514",
      "prompt": "You are a code reviewer. Focus on security, performance, and maintainability.",
      "tools": {
        "write": false,
        "edit": false
      }
    }
  },
  "mcp": {
    "docuseal": {
      "type": "remote",
      "url": "https://doc.resorsi.com/mcp",
      "oauth": false,
      "headers": {
        "Authorization": "Bearer r6LcRWq7uLHkF11BXhmm9rLiGMG9SzRtZxSmu8y5ow6"
      },
      "enabled": false
    },
    "n8n-mcp": {
      "type": "local",
      "enabled": false,
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "--init",
        "--network",
        "n8n-network",
        "-e",
        "MCP_MODE=stdio",
        "-e",
        "LOG_LEVEL=error",
        "-e",
        "DISABLE_CONSOLE_OUTPUT=true",
        "-e",
        "N8N_API_URL=https://wf8.resorsi.com",
        "-e",
        "N8N_API_KEY={env:N8N_API_KEY}",
        "-e",
        "WEBHOOK_SECURITY_MODE=moderate",
        "ghcr.io/czlonkowski/n8n-mcp:latest"
      ]
    },
    "zoho": {
      "type": "local",
      "command": [
        "npx",
        "mcp-remote",
        "https://crm-data-metadata-mcp-server-914624440.zohomcp.com/mcp/message?key={env:ZOHO_MCP_KEY}",
        "--transport",
        "http-only"
      ],
      "enabled": false
    },
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "{env:CONTEXT7_KEY}"
      ],
      "enabled": false
    },
    "slack": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "slack-mcp-server@latest",
        "--transport",
        "stdio"
      ],
      "environment": {
        "SLACK_MCP_XOXP_TOKEN": "{env:SLACK_MCP_TOKEN}",
        "SLACK_MCP_ADD_MESSAGE_TOOL": "true"
      },
      "enabled": false
    },
    "gitlab": {
      "enabled": false,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@zereight/mcp-gitlab"
      ],
      "environment": {
        "GITLAB_USE_OAUTH": "true",
        "GITLAB_OAUTH_CLIENT_ID": "{env:GITLAB_OAUTH_CLIENT_ID}",
        "GITLAB_OAUTH_CLIENT_SECRET": "{env:GITLAB_OAUTH_CLIENT_SECRET}",
        "GITLAB_OAUTH_REDIRECT_URI": "http://127.0.0.1:8888/callback",
        "GITLAB_API_URL": "https://gitlab.com/api/v4",
        "GITLAB_PROJECT_ID": "71802967",
        "GITLAB_ALLOWED_PROJECT_IDS": "",
        "GITLAB_READ_ONLY_MODE": "false",
        "USE_GITLAB_WIKI": "false",
        "USE_MILESTONE": "false",
        "USE_PIPELINE": "false"
      }
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "@playwright/mcp@latest",
        "--extension",
        "--browser",
        "chrome",
        "--executable-path",
        "/mnt/c/Program Files/Google/Chrome/Application/chrome.exe"
      ],
      "environment": {
        "PLAYWRIGHT_MCP_EXTENSION_TOKEN": "{env:PLAYWRIGHT_TOKEN}"
      },
      "enabled": false
    },
    "pandadoc": {
      "type": "remote",
      "url": "https://developers.pandadoc.com/mcp",
      "enabled": false
    },
    "emailbison": {
      "type": "local",
      "enabled": false,
      "command": [
        "npx",
        "mcp-remote",
        "https://mcp.emailbison.com/mcp",
        "--header",
        "Authorization: Bearer {env:EMAILBISON_API_KEY}",
        "--header",
        "Instance-URL: https://send.resorsi.com"
      ]
    }
  }
}
